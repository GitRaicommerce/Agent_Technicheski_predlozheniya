# TP AI - Environment Variables
# Copy this file to .env and fill in the values

# Database
POSTGRES_DB=tpai
POSTGRES_USER=tpai
POSTGRES_PASSWORD=tpai_dev
DATABASE_URL=postgresql+asyncpg://tpai:tpai_dev@postgres:5432/tpai

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_FILES=tp-files
MINIO_BUCKET_EXPORTS=tp-exports
MINIO_SECURE=false

# LLM (задължителни - добавете в GitHub Secrets за Codespaces)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LLM настройки
LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_MODEL=gpt-4o
LLM_FALLBACK_MODEL=claude-3-5-sonnet-20241022
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMS=1536

# CORS (JSON list format — required by pydantic-settings)
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# App
APP_SECRET_KEY=change-me-in-production
APP_ENV=development
LOG_LEVEL=INFO
